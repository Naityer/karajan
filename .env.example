# KARAJAN local environment template.
# Copy to .env or let KARAJAN Desktop.bat create .env automatically.

# Leave empty to keep local mutation auth disabled.
KARAJAN_TOKEN=

# Logging level: DEBUG, INFO, WARNING, ERROR.
KARAJAN_LOG_LEVEL=INFO

# Optional runtime config override path.
# KARAJAN_CONFIG=data/active_config.json

# Optional provider keys for API-backed providers.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
# GEMINI_API_KEY=
# GROQ_API_KEY=
# DEEPSEEK_API_KEY=
# ZAI_API_KEY=
# TOGETHER_API_KEY=
# OPENROUTER_API_KEY=
# HF_TOKEN=
# MISTRAL_API_KEY=
